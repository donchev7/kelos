#!/usr/bin/env bash
# pnpm wrapper: requests a GitHub Packages token from cody-tools and exports it
# as NODE_AUTH_TOKEN before exec'ing the real pnpm binary.
#
# Sits at /usr/local/bin/pnpm, which is ahead of /usr/bin/pnpm in PATH, so
# any `pnpm` invocation (from the agent, from shells, from scripts) picks
# up GitHub Packages auth for the @quantum-wealth scope without per-call
# plumbing. pnpm reads .npmrc the same way npm does, so the line
# `//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}` resolves against
# the token the wrapper exports.
#
# Mirrors codex/scripts/npm exactly — pnpm doesn't shell out to npm, so
# the npm wrapper does not cover pnpm invocations on its own.
#
# If NODE_AUTH_TOKEN is already set (operator override, CI injection,
# or a previous wrapped npm call in the same shell), the wrapper does
# nothing — the existing token wins and real pnpm sees it unchanged.
#
# cody-tools keeps the package token server-side and returns it through the
# package-token route only when pnpm runs. GitHub App tokens remain used for
# git and gh, not for npm.pkg.github.com package installs.
set -euo pipefail

if [[ -z "${NODE_AUTH_TOKEN:-}" ]]; then
  NODE_AUTH_TOKEN=$(/usr/local/bin/cody-github-token --purpose pnpm)
  export NODE_AUTH_TOKEN
fi

exec /usr/bin/pnpm "$@"
